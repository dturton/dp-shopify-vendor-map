# Vendor MAP Pricing App — environment variables
# Copy to `.env` and fill in. `.env` is gitignored.

# --- Database (required) ---------------------------------------------------
# Postgres connection string used by Prisma (session storage + CsvJob).
# Local dev example (Docker): see README "Local Postgres".
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vendor_map?schema=public"

# --- Shopify app credentials ----------------------------------------------
# During `shopify app dev` the CLI injects these automatically — you do NOT
# need to set them locally. Set them yourself only for production/hosting (Fly).
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_APP_URL=""

# Access scopes (must match shopify.app.toml). CLI injects this during dev.
SCOPES="read_products,write_products,read_cart_transforms,write_cart_transforms"

# Optional: custom shop domain override for local testing only.
# SHOP_CUSTOM_DOMAIN=""
