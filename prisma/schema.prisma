// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Required by @shopify/shopify-app-session-storage-prisma.
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Tracks bulk CSV import jobs. Populated in Phase 2 (CSV import/export);
// defined now so the schema and migrations are stable from Phase 1.
enum CsvJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model CsvJob {
  id           String       @id @default(uuid())
  shopDomain   String
  status       CsvJobStatus @default(PENDING)
  successCount Int          @default(0)
  errorCount   Int          @default(0)
  // Free-form job payload (parsed rows, diff preview, error details, etc.).
  payload      Json?
  createdAt    DateTime     @default(now())
  completedAt  DateTime?

  @@index([shopDomain, status])
}
