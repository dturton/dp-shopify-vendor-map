{% comment %}
  MAP price notice (app block).

  Renders a "List Price / MAP" treatment on MAP-enabled products and prompts the
  shopper to add to cart to see their actual price. Reads ONLY the storefront-
  visible boolean flag `map_enabled` from the app's reserved metafield namespace
  (e.g. `app--368457482241`), which must have storefront PUBLIC_READ access. The
  namespace is configured via the "App metafield namespace" block setting; we read
  it with bracket notation `variant.metafields[ns].map_enabled` because reserved
  namespaces (with `--` and digits) can't be dot-accessed in Liquid. The real
  discounted price (`actual_price`) is admin-only and is never exposed here —
  preserving MAP compliance. The displayed price is `variant.price` (the MAP).

  Place this block near the price on the product template.
{% endcomment %}

{%- liquid
  assign ns = block.settings.app_namespace
  assign variant = product.selected_or_first_available_variant

  assign current_mf = variant.metafields[ns].map_enabled
  if current_mf == blank
    assign current_mf = variant.metafields.app.map_enabled
  endif
  assign current_enabled = current_mf.value

  assign has_any_map = false
  for v in product.variants
    assign vmf = v.metafields[ns].map_enabled
    if vmf == blank
      assign vmf = v.metafields.app.map_enabled
    endif
    if vmf.value
      assign has_any_map = true
      break
    endif
  endfor
-%}

{%- if block.settings.debug_mode -%}
  <pre class="map-notice-debug" style="white-space:pre-wrap;background:#fffbe6;border:2px solid #c0392b;color:#111;padding:10px;margin:10px 0;font-size:12px;line-height:1.4;">MAP price notice — DEBUG (turn this off when done)
namespace setting (ns): [{{ ns }}]
product present: {% if product %}yes{% else %}no{% endif %}
has_any_map: {{ has_any_map }}
selected variant id: {{ variant.id }}
--- via literal namespace: metafields[ns] ---
value: [{{ variant.metafields[ns].map_enabled.value }}]  type: [{{ variant.metafields[ns].map_enabled.type }}]
keys readable in metafields[ns]:
{% for f in variant.metafields[ns] %}  - {{ f.first }} = [{% if f.first == 'actual_price' %}hidden{% else %}{{ f.last.value }}{% endif %}] ({{ f.last.type }})
{% else %}  (none readable here)
{% endfor %}--- via app alias: metafields.app ---
value: [{{ variant.metafields.app.map_enabled.value }}]
keys readable in metafields.app:
{% for f in variant.metafields.app %}  - {{ f.first }} = [{% if f.first == 'actual_price' %}hidden{% else %}{{ f.last.value }}{% endif %}] ({{ f.last.type }})
{% else %}  (none readable here)
{% endfor %}If BOTH say "none readable": storefront PUBLIC_READ not granted yet (run Settings -> Register definitions).
If the literal one shows map_enabled but the alias doesn't: namespace setting is correct, badge will work.</pre>
{%- endif -%}

{%- if product and has_any_map -%}
  <div
    class="map-notice{% if block.settings.show_box %} map-notice--boxed{% endif %}"
    data-map-notice
    data-hide-native-price="{{ block.settings.hide_native_price }}"
    data-native-price-selector="{{ block.settings.native_price_selector | escape }}"
    {% unless current_enabled %}hidden{% endunless %}
    style="--map-font-size: {{ block.settings.font_size }}px; --map-box-bg: {{ block.settings.box_bg }}; --map-box-border: {{ block.settings.box_border }}; --map-badge-bg: {{ block.settings.badge_bg }}; --map-badge-color: {{ block.settings.badge_color }}; --map-accent: {{ block.settings.accent_color }};"
    {{ block.shopify_attributes }}
  >
    {%- if block.settings.show_badge -%}
      <div class="map-notice__row">
        <span class="map-notice__badge">{{ block.settings.badge_text }}</span>
        {%- if block.settings.tooltip_text != blank -%}
          <span class="map-notice__info">
            <button type="button" class="map-notice__info-toggle" aria-label="{{ 'map_notice.info_label' | t }}">
              <span aria-hidden="true">i</span>
            </button>
            <span class="map-notice__info-content" role="tooltip">{{ block.settings.tooltip_text }}</span>
          </span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if block.settings.show_label -%}
      <div class="map-notice__price-row">
        <span class="map-notice__label">{{ block.settings.list_price_label }}</span>
        <span class="map-notice__price" data-map-price>{{ variant.price | money }}</span>
      </div>
    {%- endif -%}

    {%- if block.settings.show_disclaimer and block.settings.disclaimer_text != blank -%}
      <p class="map-notice__disclaimer">{{ block.settings.disclaimer_text }}</p>
    {%- endif -%}

    <script type="application/json" data-map-notice-data>
      {
        "variants": {
          {%- for v in product.variants -%}
            {%- assign vmf = v.metafields[ns].map_enabled -%}
            {%- if vmf == blank -%}{%- assign vmf = v.metafields.app.map_enabled -%}{%- endif -%}
            "{{ v.id }}": {"enabled": {% if vmf.value %}true{% else %}false{% endif %}, "price": {{ v.price | money | json }}}{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        }
      }
    </script>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "MAP price notice",
  "target": "section",
  "stylesheet": "map-price-notice.css",
  "javascript": "map-price-notice.js",
  "settings": [
    {
      "type": "paragraph",
      "content": "Shows a MAP / list-price notice on products that have MAP pricing enabled (variant 'MAP enabled' is on). Place it near the price. It stays hidden on non-MAP products and variants."
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show MAP badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "MAP"
    },
    {
      "type": "textarea",
      "id": "tooltip_text",
      "label": "Badge info tooltip",
      "info": "Shown when the shopper hovers/focuses the info (i) icon. Leave blank to hide the icon.",
      "default": "MAP is the Minimum Advertised Price. Add this item to your cart to see your actual (lower) price."
    },
    {
      "type": "checkbox",
      "id": "show_label",
      "label": "Show price with \"List Price\" label",
      "default": true
    },
    {
      "type": "text",
      "id": "list_price_label",
      "label": "Price label",
      "default": "List Price"
    },
    {
      "type": "checkbox",
      "id": "show_disclaimer",
      "label": "Show add-to-cart disclaimer",
      "default": true
    },
    {
      "type": "text",
      "id": "disclaimer_text",
      "label": "Disclaimer text",
      "default": "Add to cart to view your discounted price"
    },
    {
      "type": "header",
      "content": "Hide the theme's price (optional)"
    },
    {
      "type": "paragraph",
      "content": "Hides your theme's own price element on MAP products only, so just the notice above shows. Non-MAP products keep their normal price."
    },
    {
      "type": "checkbox",
      "id": "hide_native_price",
      "label": "Hide the theme's price on MAP products",
      "default": false
    },
    {
      "type": "text",
      "id": "native_price_selector",
      "label": "Theme price CSS selector",
      "info": "CSS selector of your theme's price element to hide (e.g. .price). Use the debug toggle / inspect the page to confirm.",
      "default": ".price"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Text size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "checkbox",
      "id": "show_box",
      "label": "Show container box (like the reference)",
      "default": true
    },
    {
      "type": "color",
      "id": "box_bg",
      "label": "Box background",
      "default": "#f6f7f9"
    },
    {
      "type": "color",
      "id": "box_border",
      "label": "Box border",
      "default": "#e3e6ea"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge background",
      "default": "#c0392b"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Badge text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Label & price color",
      "default": "#c0392b"
    },
    {
      "type": "header",
      "content": "Developer"
    },
    {
      "type": "text",
      "id": "app_namespace",
      "label": "App metafield namespace",
      "info": "The app's reserved namespace shown in Settings → Custom data → Variant metafields (e.g. app--368457482241). The block reads map_enabled from here.",
      "default": "app--368457482241"
    },
    {
      "type": "checkbox",
      "id": "debug_mode",
      "label": "Debug (temporary) — print what Liquid can read",
      "default": false
    }
  ]
}
{% endschema %}
